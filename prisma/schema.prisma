// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Expenses {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description       String?
  tags              String[]
  amount            Decimal?  @db.Decimal(10, 2)
  modeOfPayment     String?
  notes             String?
  taxClassification String?
  createdAt         DateTime  @default(now()) @db.Timestamp(6)
  updatedAt         DateTime? @db.Timestamp(6)

  request_id String?  @db.Uuid
  request    Request? @relation(fields: [request_id], references: [id], onDelete: Cascade)
}

model Request {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectCode    String    @unique
  requestor      String?
  storeName      String?
  storeCategory  String?
  tinNo          String?
  deliveryStatus String    @default("pending")
  orNumber       String?
  inTrash        Boolean   @default(false)
  updatedBy      String
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime? @db.Timestamp(6)

  purchaseOrders PurchaseOrder[]
  expenses       Expenses[]
}

model PurchaseOrder {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poNumber String  @unique
  status   Boolean @default(true)

  request_id String  @db.Uuid
  request    Request @relation(fields: [request_id], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @db.Timestamp(6)
}

model Product {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productName       String
  numOfOrderedStock Int
  amount            Decimal? @db.Decimal(10, 2)
  status            Boolean  @default(true)

  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @db.Timestamp(6)

  purchaseOrder_id String        @db.Uuid
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrder_id], references: [id], onDelete: Cascade)

  deliveryItems DeliveryItem[]
  invoiceItems  InvoiceItem[]
}

model DeliveryReceipt {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiptNo     String    @unique
  dateDelivered DateTime? @db.Timestamp(6)
  status        Boolean   @default(true)

  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @db.Timestamp(6)

  items DeliveryItem[]
}

model DeliveryItem {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quantityDelivered Int

  product_id String  @db.Uuid
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  deliveryReceipt_id String          @db.Uuid
  deliveryReceipt    DeliveryReceipt @relation(fields: [deliveryReceipt_id], references: [id], onDelete: Cascade)
}

model ServiceInvoice {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNo String   @unique
  amountDue Decimal? @db.Decimal(10, 2)
  status    Boolean  @default(true)

  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @db.Timestamp(6)

  items       InvoiceItem[]
  allocations PaymentAllocation[]
}

model InvoiceItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quantityBilled Int
  amountBilled   Decimal? @db.Decimal(10, 2)

  product_id String  @db.Uuid
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  serviceInvoice_id String         @db.Uuid
  serviceInvoice    ServiceInvoice @relation(fields: [serviceInvoice_id], references: [id], onDelete: Cascade)
}

model CollectionReceipt {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiptNo  String   @unique
  amountPaid Decimal? @db.Decimal(10, 2)
  status     Boolean  @default(true)

  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @db.Timestamp(6)

  allocations PaymentAllocation[]
}

model PaymentAllocation {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  collectionId  String  @db.Uuid
  invoiceId     String  @db.Uuid
  amountApplied Decimal @db.Decimal(10, 2)

  collection CollectionReceipt @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  invoice    ServiceInvoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([collectionId, invoiceId])
}

model User {
  id       String   @id @db.Uuid
  email    String?  @unique
  username String?
  roles    String[] @default(["user"])
}
